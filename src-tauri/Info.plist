<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleIdentifier</key>
  <string>com.debugduck.widget</string>
  <key>CFBundleName</key>
  <string>DebugDuck</string>
  <key>CFBundleVersion</key>
  <string>0.1.0</string>
  <key>CFBundleShortVersionString</key>
  <string>0.1.0</string>
  <!-- Allow HTTP connections to localhost (LM Studio on :1234) -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsLocalNetworking</key>
    <true/>
  </dict>
  <key>NSMicrophoneUsageDescription</key>
  <string>DebugDuck necesita el microfono para escuchar tu codigo.</string>
  <key>NSSpeechRecognitionUsageDescription</key>
  <string>DebugDuck usa reconocimiento de voz para transcribir lo que describes.</string>
</dict>
</plist>
